_format_version: "1.1"

# =============================================================================
# Kong Declarative Config for Supabase Self-Hosted
# All service hostnames use "eventos-" prefix
# IMPORTANT: Replace ANON_KEY and SERVICE_ROLE_KEY with actual JWT values
# Kong does NOT support environment variable substitution
# =============================================================================

consumers:
  - username: DASHBOARD
  - username: anon
    keyauth_credentials:
      - key: YOUR_ANON_KEY_HERE
  - username: service_role
    keyauth_credentials:
      - key: YOUR_SERVICE_ROLE_KEY_HERE

acls:
  - consumer: anon
    group: anon
  - consumer: service_role
    group: admin

# =============================================================================
# Services
# =============================================================================

services:
  # ---------------------------------------------------------------------------
  # Auth (GoTrue)
  # ---------------------------------------------------------------------------
  - name: auth-v1-open
    url: http://eventos-auth:9999/verify
    routes:
      - name: auth-v1-open
        strip_path: true
        paths:
          - /auth/v1/verify
    plugins:
      - name: cors

  - name: auth-v1-open-callback
    url: http://eventos-auth:9999/callback
    routes:
      - name: auth-v1-open-callback
        strip_path: true
        paths:
          - /auth/v1/callback
    plugins:
      - name: cors

  - name: auth-v1-open-authorize
    url: http://eventos-auth:9999/authorize
    routes:
      - name: auth-v1-open-authorize
        strip_path: true
        paths:
          - /auth/v1/authorize
    plugins:
      - name: cors

  - name: auth-v1
    _comment: "GoTrue: /auth/v1/* -> eventos-auth:9999"
    url: http://eventos-auth:9999/
    routes:
      - name: auth-v1
        strip_path: true
        paths:
          - /auth/v1/
    plugins:
      - name: cors
      - name: key-auth
        config:
          hide_credentials: false
      - name: acl
        config:
          hide_groups_header: true
          allow:
            - admin
            - anon

  # ---------------------------------------------------------------------------
  # PostgREST (REST API)
  # ---------------------------------------------------------------------------
  - name: rest-v1
    _comment: "PostgREST: /rest/v1/* -> eventos-rest:3000"
    url: http://eventos-rest:3000/
    routes:
      - name: rest-v1
        strip_path: true
        paths:
          - /rest/v1/
    plugins:
      - name: cors
      - name: key-auth
        config:
          hide_credentials: true
      - name: acl
        config:
          hide_groups_header: true
          allow:
            - admin
            - anon

  # ---------------------------------------------------------------------------
  # Realtime (WebSocket)
  # ---------------------------------------------------------------------------
  - name: realtime-v1
    _comment: "Realtime: /realtime/v1/* -> eventos-realtime:4000"
    url: http://eventos-realtime:4000/socket/
    routes:
      - name: realtime-v1
        strip_path: true
        paths:
          - /realtime/v1/
    plugins:
      - name: cors
      - name: key-auth
        config:
          hide_credentials: false
      - name: acl
        config:
          hide_groups_header: true
          allow:
            - admin
            - anon

  # ---------------------------------------------------------------------------
  # Storage
  # ---------------------------------------------------------------------------
  - name: storage-v1
    _comment: "Storage: /storage/v1/* -> eventos-storage:5000"
    url: http://eventos-storage:5000/
    routes:
      - name: storage-v1
        strip_path: true
        paths:
          - /storage/v1/
    plugins:
      - name: cors

  # ---------------------------------------------------------------------------
  # PG Meta (for Studio)
  # ---------------------------------------------------------------------------
  - name: meta
    _comment: "PG Meta: /pg/* -> eventos-meta:8080"
    url: http://eventos-meta:8080/
    routes:
      - name: meta
        strip_path: true
        paths:
          - /pg/
    plugins:
      - name: key-auth
        config:
          hide_credentials: false
      - name: acl
        config:
          hide_groups_header: true
          allow:
            - admin
