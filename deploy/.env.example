# =============================================================================
# AppEventosSegopi - Environment Variables for Docker Swarm
# Copy to .env and fill in the values
# =============================================================================

# Secrets (generate with: openssl rand -base64 24)
POSTGRES_PASSWORD=
JWT_SECRET=
SECRET_KEY_BASE=

# JWT Keys (generate at https://supabase.com/docs/guides/self-hosting#api-keys)
ANON_KEY=
SERVICE_ROLE_KEY=

# Studio Dashboard
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=

# Domains
SITE_URL=https://eventos.segopi.es
API_EXTERNAL_URL=https://supabase-api.segopi.es
SUPABASE_PUBLIC_URL=https://supabase-api.segopi.es

# SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# App
ADMIN_NOTIFICATION_EMAIL=
CRON_SECRET=
